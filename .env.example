# Copy this file to .env and fill in your values.
# Gmail users: create an App Password at https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled on your account)

NOTIFIER_SMTP_HOST=smtp.gmail.com
NOTIFIER_SMTP_PORT=587
NOTIFIER_SMTP_USER=you@gmail.com
NOTIFIER_SMTP_PASSWORD=your-app-password-here
NOTIFIER_FROM=you@gmail.com
NOTIFIER_TO=you@gmail.com
